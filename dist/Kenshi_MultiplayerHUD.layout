<MyGUI type="Layout" version="3.2.0">
    <!-- ═══ In-game Multiplayer HUD (native Kenshi UI) ═══ -->
    <!-- Non-interactive fullscreen container — does NOT block clicks -->
    <Widget type="Widget" skin="PanelEmpty" position_real="0 0 1 1" layer="Main" name="HUDRoot">
        <Property key="NeedMouse" value="false"/>
        <Property key="Visible" value="false"/>
        <Property key="InheritsAlpha" value="false"/>

        <!-- ═══ CONNECTION STATUS BAR (top-center, always visible) ═══ -->
        <Widget type="Widget" skin="Kenshi_FloatingPanelSkin" position_real="0.3 0.003 0.4 0.04" align="HCenter Top" name="HUDStatusBar">
            <Property key="InheritsAlpha" value="false"/>
            <Property key="NeedMouse" value="false"/>
            <Property key="Alpha" value="0.85"/>

            <Widget type="TextBox" skin="Kenshi_TextboxStandardText" position_real="0.02 0.05 0.96 0.9" align="Stretch" name="HUDStatusText">
                <Property key="Caption" value="KENSHI ONLINE  |  Not Connected  |  F1 = Menu"/>
                <Property key="TextAlign" value="Center VCenter"/>
                <Property key="TextColour" value="0.9 0.55 0.1"/>
                <Property key="NeedMouse" value="false"/>
            </Widget>
        </Widget>

