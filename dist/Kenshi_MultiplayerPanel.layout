                    <Property key="TextAlign" value="Center"/>
                    <Property key="TextColour" value="0.9 0.55 0.1"/>
                </Widget>
            </Widget>

            <!-- ═══ SETTINGS sub-panel (hidden by default) ═══ -->
            <Widget type="Widget" skin="PanelEmpty" position_real="0.05 0.13 0.9 0.75" align="Stretch" name="MPSettingsPanel">
                <Property key="Visible" value="false"/>

                <Widget type="TextBox" skin="Kenshi_TextboxStandardText" position_real="0.0 0.0 0.4 0.1" align="Left Top">
                    <Property key="Caption" value="Player Name:"/>
                    <Property key="TextAlign" value="Left VCenter"/>
