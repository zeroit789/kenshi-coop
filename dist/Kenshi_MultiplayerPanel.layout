                    <Property key="TextAlign" value="Left VCenter"/>
                    <Property key="TextColour" value="0.871345 0.845139 0.810198"/>
                </Widget>
                <Widget type="Button" skin="Kenshi_TickBoxSkin" position_real="0.42 0.15 0.06 0.08" align="Left Top" name="MPAutoConnectTick"/>

                <Widget type="Button" skin="Kenshi_Button1" position_real="0.25 0.5 0.5 0.14" align="HCenter Bottom" name="MPSettingsBackButton">
                    <Property key="Caption" value="BACK"/>
                    <Property key="FontName" value="Kenshi_PaintedTextFont_Large"/>
